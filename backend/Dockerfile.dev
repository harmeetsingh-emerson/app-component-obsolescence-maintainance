# =============================================================================
# Development Dockerfile — Python / FastAPI backend
#
# - No React build — the React dev server runs in a separate container.
# - Source directories are bind-mounted at runtime (see docker-compose.dev.yml)
#   so code changes are picked up by uvicorn --reload instantly.
# =============================================================================

FROM python:3.11-slim

WORKDIR /app

# System dependencies (same as prod)
RUN apt-get update && apt-get install -y --no-install-recommends \
        libgl1 \
        libglib2.0-0 \
        libsm6 \
        libxrender1 \
        libxext6 \
        libgomp1 \
        poppler-utils \
        default-jre-headless \
    && rm -rf /var/lib/apt/lists/*

# Python dependencies (installed once into the image; requirements changes
# require a rebuild: docker-compose -f docker-compose.dev.yml build backend)
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

ENV PYTHONUNBUFFERED=1
ENV KMP_DUPLICATE_LIB_OK=TRUE
ENV OLLAMA_BASE_URL=http://host.docker.internal:11434

EXPOSE 8000

# --reload watches for file changes in the bind-mounted ./app directory
CMD ["uvicorn", "app.main_faiss:app", "--host", "0.0.0.0", "--port", "8000", "--reload"]
